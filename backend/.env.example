# Copy to backend/.env for local development (never commit backend/.env)

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/transitops
JWT_SECRET_KEY=change-me-in-production

# Gmail SMTP (use an App Password, not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

OTP_EXPIRE_MINUTES=10
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30
SEED_DEMO_PASSWORD=TransitOps@123
